# Required: AWS account ID for the Shared Services account
# Note: The script auto-injects this via -var, but you can also set it here.
shared_services_account_id = "123456789012"

# Optional: Override the default region (default: ap-southeast-1)
# aws_region = "ap-southeast-1"

# Optional: GitHub username/org (default: rj-cam)
# github_org = "rj-cam"

# Optional: GitHub repo name (default: agentic-landing-zone)
# github_repo = "agentic-landing-zone"

# Optional: Name of the ECR repository (default: landing-zone/httpd)
# ecr_repository_name = "landing-zone/httpd"
