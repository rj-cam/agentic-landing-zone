# Required: Log Archive account ID
log_archive_account_id = "123456789012"

# Optional: Override the default region (default: ap-southeast-1)
# aws_region = "ap-southeast-1"

# Optional: S3 bucket name for CloudTrail logs (default: landing-zone-cloudtrail-logs)
# log_bucket_name = "landing-zone-cloudtrail-logs"

# Optional: Number of days before log expiration (default: 365)
# log_retention_days = 365

# Optional: Number of days before transition to Glacier (default: 90)
# glacier_transition_days = 90
